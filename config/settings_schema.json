        "default": "Barlow Condensed"
      },
      {
        "type": "select",
        "id": "font_body",
        "label": "Fuente para cuerpo",
        "options": [
          { "value": "Roboto", "label": "Roboto" },
          { "value": "Open Sans", "label": "Open Sans" },
          { "value": "Lato", "label": "Lato" }
        ],
        "default": "Roboto"
