<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">

  <!-- Open Graph / Social Sharing -->
  <meta property="og:type"        content="website">
  <meta property="og:title"       content="{{ page_title | escape }}">
  <meta property="og:description" content="{{ page_description | default: shop.description | escape }}">
  <meta property="og:url"         content="{{ canonical_url }}">
  <meta property="og:site_name"   content="{{ shop.name | escape }}">
  {%- if settings.favicon != blank -%}
    <meta property="og:image" content="{{ settings.favicon | img_url: '1200x630', crop: 'center' }}">
  {%- endif -%}
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content="{{ page_title | escape }}">
  <meta name="twitter:description" content="{{ page_description | default: shop.description | escape }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | img_url: '32x32' }}">
  {%- else -%}
    <link rel="icon" type="image/png" href="{{ 'icon-default.png' | asset_url }}">
  {%- endif -%}

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700&family=Oswald:wght@400;600;700&family=Roboto:wght@300;400;500;700&family=Open+Sans:wght@300;400;600&display=swap" rel="stylesheet">

  <!-- CSS Variables from Theme Settings -->
  <style>
    :root {
      --color-primary:    {{ settings.color_primary }};
      --color-accent:     {{ settings.color_accent }};
      --color-secondary:  {{ settings.color_secondary | default: '#12448F' }};
      --color-background: {{ settings.color_background }};
      --color-text:       {{ settings.color_text }};
      --color-topbar:     {{ settings.color_topbar }};
      --color-footer-bg:  {{ settings.color_footer_bg | default: '#1B3A6B' }};
      --font-heading: '{{ settings.font_heading }}', sans-serif;
      --font-body:    '{{ settings.font_body }}', sans-serif;
    }
  </style>

  {{ 'theme-base.css'       | asset_url | stylesheet_tag }}
  {{ 'theme-header.css'     | asset_url | stylesheet_tag }}
  {{ 'theme-hero.css'       | asset_url | stylesheet_tag }}
  {{ 'theme-products.css'   | asset_url | stylesheet_tag }}
  {{ 'theme-sections.css'   | asset_url | stylesheet_tag }}
  {{ 'theme-footer.css'     | asset_url | stylesheet_tag }}
  {{ 'theme-cart.css'       | asset_url | stylesheet_tag }}
  {{ 'theme-collection.css' | asset_url | stylesheet_tag }}
  {{ 'theme-responsive.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}
</head>

<body class="template-{{ template | replace: '.', ' ' | truncatewords: 1, '' | handle }}">

  {%- section 'announcement-bar' -%}
  {%- section 'header' -%}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  <!-- Cart Drawer Overlay -->
  <div id="cart-overlay" class="cart-overlay" aria-hidden="true"></div>

  <!-- Cart Drawer -->
  <div id="cart-drawer" class="cart-drawer" role="dialog" aria-modal="true" aria-label="Carrito de compras">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">{{ settings.cart_title | default: 'Tu Carrito' }}</h2>
      <button class="cart-drawer__close" id="cart-drawer-close" aria-label="Cerrar carrito">
        {%- render 'icon', icon_name: 'close', icon_size: 24 -%}
      </button>
    </div>
    <div class="cart-drawer__body" id="cart-drawer-body">
      <p class="cart-drawer__empty">{{ settings.cart_empty_text | default: 'Tu carrito está vacío.' }}</p>
    </div>
    <div class="cart-drawer__footer">
      <div class="cart-drawer__total">
        <span>{{ settings.cart_total_label | default: 'Total:' }}</span>
        <span id="cart-total">$0.00</span>
      </div>
      <a href="/cart" class="btn btn--primary btn--full">{{ settings.cart_view_label | default: 'Ver Carrito' }}</a>
      <a href="/checkout" class="btn btn--accent btn--full">{{ settings.cart_checkout_label | default: 'Proceder al Pago' }}</a>
    </div>
  </div>

  <!-- Toast notification -->
  <div id="cart-toast" class="cart-toast" role="alert" aria-live="polite"></div>

  <!-- Floating Contact Buttons -->
  {%- if settings.whatsapp_number != blank or settings.contact_phone != blank -%}
  <div class="float-contact" aria-label="Contacto rápido">

    {%- if settings.whatsapp_number != blank -%}
    <a
      class="float-contact__btn float-contact__btn--whatsapp"
      href="https://wa.me/{{ settings.whatsapp_number | remove: '+' | remove: '-' | remove: ' ' | remove: '(' | remove: ')' }}"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#fff" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      <span class="float-contact__label">WhatsApp</span>
    </a>
    {%- endif -%}

    {%- if settings.contact_phone != blank -%}
    <a
      class="float-contact__btn float-contact__btn--phone"
      href="tel:{{ settings.contact_phone | remove: ' ' }}"
      aria-label="Llamar por teléfono"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#fff" aria-hidden="true">
        <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
      </svg>
      <span class="float-contact__label">{{ settings.contact_phone }}</span>
    </a>
    {%- endif -%}

  </div>
  {%- endif -%}

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
