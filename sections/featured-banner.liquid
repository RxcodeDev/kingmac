<section class="featured-banners-section" aria-label="Ofertas destacadas">
  <div class="featured-banners">
    {%- for block in section.blocks -%}
      {%- assign bg_color = block.settings.bg_color | default: '#1B2A4A' -%}

      <a
        href="{{ block.settings.link | default: '#' }}"
        class="featured-banner-block"
        style="background-color: {{ bg_color }};"
        {{ block.shopify_attributes }}
      >
        <span class="featured-banner-block__text"
          style="color: {{ block.settings.text_color | default: '#ffffff' }};">
          {{ block.settings.text | default: 'RESALTAR OFERTA' }}
        </span>
      </a>

    {%- else -%}
      {%- comment -%} Default placeholders {%- endcomment -%}
      <div class="featured-banner-block" style="background-color: #1B2A4A;">
        <span class="featured-banner-block__text">RESALTAR OFERTA</span>
      </div>
      <div class="featured-banner-block" style="background-color: #1B2A4A;">
        <span class="featured-banner-block__text">RESALTAR OFERTA</span>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Banners destacados",
  "settings": [],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto del banner",
          "default": "RESALTAR OFERTA"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace del banner"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Color de fondo",
          "default": "#1B2A4A"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Color del texto",
          "default": "#FFFFFF"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banners destacados",
      "blocks": [
        {
          "type": "banner",
          "settings": {
            "text": "RESALTAR OFERTA",
            "bg_color": "#1B2A4A",
            "text_color": "#FFFFFF"
          }
        },
        {
          "type": "banner",
          "settings": {
            "text": "RESALTAR OFERTA",
            "bg_color": "#1B2A4A",
            "text_color": "#FFFFFF"
          }
        }
      ]
    }
  ]
}
{% endschema %}
