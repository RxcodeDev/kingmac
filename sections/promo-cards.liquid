<section class="promo-cards">
  <div class="promo-cards__inner">
    {%- for block in section.blocks -%}
      {%- liquid
        assign bg_style = ''
        if block.settings.bg_image != blank
          assign bg_style = 'background-image: url(' | append: block.settings.bg_image | append: '); background-size: cover; background-position: center;'
        elsif block.settings.asset_image != blank
          assign image_url = block.settings.asset_image | asset_url
          assign bg_style = 'background-image: url(' | append: image_url | append: '); background-size: cover; background-position: center;'
        else
          assign bg_style = 'background-color: ' | append: block.settings.bg_color | append: ';'
        endif
      -%}
      <a
        href="{{ block.settings.url | default: '#' }}"
        class="promo-card"
        style="{{ bg_style }}"
        {{ block.shopify_attributes }}
      >
        {%- unless block.settings.bg_image != blank or block.settings.asset_image != blank -%}
          <div class="promo-card__body">
            <p class="promo-card__title" style="color: {{ block.settings.title_color | default: '#FFFFFF' }};">
              {{ block.settings.title | default: 'TÍTULO' }}
            </p>
            <span class="promo-card__cta" style="color: {{ block.settings.title_color | default: '#FFFFFF' }};">
              {{ block.settings.cta | default: 'COMPRAR' }}
            </span>
          </div>
        {%- endunless -%}
      </a>
    {%- else -%}
      <a href="#" class="promo-card" style="background-image: url({{ 'promo-remates.png' | asset_url }}); background-size: cover; background-position: center;">
      </a>
      <a href="#" class="promo-card" style="background-image: url({{ 'promo-vendidos.png' | asset_url }}); background-size: cover; background-position: center;">
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Tarjetas promo",
  "limit": 1,
  "settings": [],
  "blocks": [
    {
      "type": "card",
      "name": "Tarjeta",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "ZONA DE REMATES"
        },
        {
          "type": "text",
          "id": "cta",
          "label": "Texto CTA",
          "default": "COMPRAR"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Enlace"
        },
        {
          "type": "image_picker",
          "id": "bg_image",
          "label": "Imagen de fondo (externa)"
        },
        {
          "type": "text",
          "id": "asset_image",
          "label": "Imagen de fondo (archivo en assets/)",
          "info": "Nombre del archivo, ej: promo-remates.png"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Color de fondo (si no hay imagen)",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "title_color",
          "label": "Color del texto",
          "default": "#FFFFFF"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tarjetas promo",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "ZONA DE REMATES",
            "cta": "COMPRAR",
            "asset_image": "promo-remates.png",
            "bg_color": "#1B6CB3",
            "title_color": "#FFFFFF"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "LO MÁS VENDIDO",
            "cta": "COMPRAR",
            "asset_image": "promo-vendidos.png",
            "bg_color": "#E87722",
            "title_color": "#FFFFFF"
          }
        }
      ]
    }
  ]
}
{% endschema %}
