<footer class="site-footer" role="contentinfo" aria-label="Pie de página">

  <!-- Footer Columns -->
  <div class="site-footer__top">

    <!-- Column 1: Logo + Social -->
    <div class="footer-col">
      <div class="footer-col__logo">
        {%- render 'logo',
          logo_image:   section.settings.logo,
          logo_height:  48,
          logo_variant: 'white',
          logo_loading: 'lazy'
        -%}
      </div>

      {%- render 'social-icons' -%}
    </div>

    <!-- Column 2: Customer Service -->
    <div class="footer-col">
      <h3 class="footer-col__heading">{{ section.settings.col2_heading | default: 'SERVICIO AL CLIENTE' }}</h3>
      <p class="footer-col__text">
        {%- if section.settings.col2_email != blank -%}
          <a href="mailto:{{ section.settings.col2_email }}" class="footer-col__link">
            {{ section.settings.col2_email }}
          </a>
        {%- else -%}
          <a href="mailto:kingdenmex@gmail.com" class="footer-col__link">kingdenmex@gmail.com</a>
        {%- endif -%}
      </p>
    </div>

    <!-- Column 3: Contact -->
    <div class="footer-col">
      <h3 class="footer-col__heading">{{ section.settings.col3_heading | default: 'CONTACTO' }}</h3>
      <p class="footer-col__text">
        {%- if section.settings.col3_phone != blank -%}
          <a href="tel:{{ section.settings.col3_phone | replace: ' ', '' | replace: '-', '' }}" class="footer-col__link">
            {{ section.settings.col3_phone }}
          </a>
        {%- else -%}
          <a href="tel:5555555555" class="footer-col__link">55-5555-5555</a>
        {%- endif -%}
      </p>
    </div>

    <!-- Column 4: Legal -->
    <div class="footer-col">
      <h3 class="footer-col__heading">{{ section.settings.col4_heading | default: 'TÉRMINOS Y CONDICIONES' }}</h3>
      {%- if section.settings.privacy_policy_url != blank -%}
        <a href="{{ section.settings.privacy_policy_url }}" class="footer-col__link">Aviso de privacidad</a>
      {%- else -%}
        <a href="/pages/aviso-de-privacidad" class="footer-col__link">Aviso de privacidad</a>
      {%- endif -%}
      <a href="/pages/politica-de-devolucion" class="footer-col__link">Política de devolución</a>
      <a href="/pages/politica-de-entrega" class="footer-col__link">Política de entrega</a>
      <a href="/pages/politica-de-compra" class="footer-col__link">Política de compra</a>
    </div>

  </div><!-- /.site-footer__top -->

  <!-- Legal info row -->
  <div class="site-footer__legal">
    <div class="footer-legal__item">
      <h4 class="footer-legal__heading">Domicilio Fiscal</h4>
      <p class="footer-legal__text">
        {{ section.settings.fiscal_address | default: 'PASEO DE LAS FACULTADES 30, 04360, COPILCO UNIVERSIDAD, COYOACAN, CIUDAD DE MEXICO.' }}
      </p>
    </div>

    <div class="footer-legal__item">
      <h4 class="footer-legal__heading">Métodos de Pago</h4>
      <p class="footer-legal__text">
        {{ section.settings.payment_text_openpay | default: 'Los pagos serán procesados mediante la pasarela de Openpay.' }}
        {{ section.settings.payment_text_mercadopago | default: 'Los pagos serán procesados mediante la pasarela de Mercado Pago.' }}
      </p>
    </div>
  </div>

  <!-- Divider -->
  <hr class="site-footer__divider" aria-hidden="true">

  <!-- Copyright -->
  <div class="site-footer__bottom">
    <p>
      {{ section.settings.copyright_text | default: '© KINGDEN 2026 TODOS LOS DERECHOS RESERVADOS' }}
    </p>
    <div class="powered-by">
      <span>Powered by</span>
      <a href="https://www.instagram.com/rectrackmarketingdigital?igsh=MTJpM2QzdmRtam9qcA%3D%3D&utm_source=qr" target="_blank" rel="noopener noreferrer" aria-label="RecTrack Marketing Digital">
        <img src="{{ 'dev.png' | asset_url }}" alt="RecTrack Marketing Digital" width="120" height="auto" loading="lazy">
      </a>
    </div>
  </div>

</footer>

{% schema %}
{
  "name": "Pie de página",
  "limit": 1,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (versión clara/blanca)"
    },
    {
      "type": "header",
      "content": "Columna 2 — Servicio al cliente"
    },
    {
      "type": "text",
      "id": "col2_heading",
      "label": "Título columna 2",
      "default": "SERVICIO AL CLIENTE"
    },
    {
      "type": "text",
      "id": "col2_email",
      "label": "Email",
      "default": "kingdenmex@gmail.com"
    },
    {
      "type": "header",
      "content": "Columna 3 — Contacto"
    },
    {
      "type": "text",
      "id": "col3_heading",
      "label": "Título columna 3",
      "default": "CONTACTO"
    },
    {
      "type": "text",
      "id": "col3_phone",
      "label": "Teléfono",
      "default": "55 5659 5681"
    },
    {
      "type": "header",
      "content": "Columna 4 — Legal"
    },
    {
      "type": "text",
      "id": "col4_heading",
      "label": "Título columna 4",
      "default": "TÉRMINOS Y CONDICIONES"
    },
    {
      "type": "url",
      "id": "privacy_policy_url",
      "label": "URL aviso de privacidad"
    },
    {
      "type": "url",
      "id": "cookies_url",
      "label": "URL política de cookies"
    },
    {
      "type": "textarea",
      "id": "fiscal_address",
      "label": "Domicilio fiscal",
      "default": "PASEO DE LAS FACULTADES 30, 04360, COPILCO UNIVERSIDAD, COYOACAN, CIUDAD DE MEXICO."
    },
    {
      "type": "header",
      "content": "Métodos de Pago"
    },
    {
      "type": "text",
      "id": "payment_text_openpay",
      "label": "Texto Openpay",
      "default": "Los pagos serán procesados mediante la pasarela de Openpay."
    },
    {
      "type": "text",
      "id": "payment_text_mercadopago",
      "label": "Texto Mercado Pago",
      "default": "Los pagos serán procesados mediante la pasarela de Mercado Pago."
    },
    {
      "type": "header",
      "content": "Copyright"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Texto de copyright",
      "default": "© KINGDEN 2026 TODOS LOS DERECHOS RESERVADOS"
    }
  ]
}
{% endschema %}
