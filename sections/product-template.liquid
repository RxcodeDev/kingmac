{%- comment -%}
  SECTION: product-template.liquid
  Vista de detalle del producto individual.
  Usada en templates/product.json
{%- endcomment -%}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign product_images  = product.images -%}

<!-- ═══ BREADCRUMB ════════════════════════════════════════════════════════ -->
<div class="collection-breadcrumb">
  <div class="container">
    <nav aria-label="Ruta de navegación">
      <ol class="breadcrumb">
        <li class="breadcrumb__item"><a href="/">Inicio</a></li>
        <li class="breadcrumb__item breadcrumb__item--sep" aria-hidden="true">/</li>
        {%- if product.collections.first -%}
          <li class="breadcrumb__item">
            <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
          </li>
          <li class="breadcrumb__item breadcrumb__item--sep" aria-hidden="true">/</li>
        {%- endif -%}
        <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">
          {{ product.title | truncate: 48 }}
        </li>
      </ol>
    </nav>
  </div>
</div>

<!-- ═══ PRODUCT MAIN ══════════════════════════════════════════════════════ -->
<section class="product-page" aria-label="{{ product.title }}">
  <div class="container product-page__container">

    <!-- ── GALLERY ─────────────────────────────────────────────────────── -->
    <div class="product-gallery" id="product-gallery">

      <!-- Imagen principal -->
      <div class="product-gallery__main">
        {%- if product.featured_image != blank -%}
          <img
            id="gallery-main-img"
            class="product-gallery__main-img"
            src="{{ product.featured_image | img_url: '800x800', crop: 'center' }}"
            alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
            width="800"
            height="800"
            loading="eager"
          >
        {%- else -%}
          <div class="product-gallery__placeholder">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg product-gallery__placeholder-svg' }}
          </div>
        {%- endif -%}

        {%- if product.compare_at_price > product.price -%}
          <span class="product-gallery__badge">OFERTA</span>
        {%- endif -%}
        {%- unless product.available -%}
          <span class="product-gallery__badge product-gallery__badge--out">AGOTADO</span>
        {%- endunless -%}
      </div>

      <!-- Miniaturas -->
      {%- if product_images.size > 1 -%}
        <div class="product-gallery__thumbs" role="list" aria-label="Imágenes del producto">
          {%- for image in product_images -%}
            <button
              class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}"
              type="button"
              data-full="{{ image | img_url: '800x800', crop: 'center' }}"
              data-alt="{{ image.alt | escape | default: product.title | escape }}"
              aria-label="Ver imagen {{ forloop.index }}"
              role="listitem"
            >
              <img
                src="{{ image | img_url: '120x120', crop: 'center' }}"
                alt="{{ image.alt | escape | default: product.title | escape }}"
                width="120"
                height="120"
                loading="lazy"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div><!-- /.product-gallery -->

    <!-- ── INFO ────────────────────────────────────────────────────────── -->
    <div class="product-info">

      <!-- Vendor / SKU -->
      <div class="product-info__meta">
        {%- if product.vendor != blank -%}
          <span class="product-info__vendor">{{ product.vendor }}</span>
        {%- endif -%}
        {%- if current_variant.sku != blank -%}
          <span class="product-info__sku">SKU: {{ current_variant.sku }}</span>
        {%- endif -%}
      </div>

      <!-- Título -->
      <h1 class="product-info__title">{{ product.title }}</h1>

      <!-- Precio -->
      <div class="product-info__price-wrap" id="product-price-wrap">
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="product-info__price--compare">
            {{ current_variant.compare_at_price | money }}
          </span>
        {%- endif -%}
        <span class="product-info__price" id="product-price">
          {{ current_variant.price | money }}
        </span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          {%- assign saving = current_variant.compare_at_price | minus: current_variant.price -%}
          {%- assign pct = saving | times: 100 | divided_by: current_variant.compare_at_price -%}
          <span class="product-info__badge">-{{ pct }}%</span>
        {%- endif -%}
      </div>

      <!-- Descripción corta -->
      {%- if product.description != blank -%}
        <div class="product-info__desc-short">
          {{ product.description | strip_html | truncate: 200 }}
        </div>
      {%- endif -%}

      <!-- Separador -->
      <hr class="product-info__divider">

      <!-- Variantes -->
      {%- if product.variants.size > 1 -%}
        <div class="product-info__variants">
          <label class="product-info__label" for="variant-select">
            {{ product.options.first }}:
            <span class="product-info__option-val" id="selected-option-text">
              {{ current_variant.option1 }}
            </span>
          </label>
          <div class="product-variants-grid" id="variant-btns">
            {%- for variant in product.variants -%}
              <button
                class="variant-btn{% if variant.id == current_variant.id %} is-selected{% endif %}{% unless variant.available %} is-unavailable{% endunless %}"
                type="button"
                data-variant-id="{{ variant.id }}"
                data-price="{{ variant.price | money }}"
                data-compare="{{ variant.compare_at_price | money }}"
                data-option="{{ variant.option1 }}"
                data-available="{{ variant.available }}"
                data-sku="{{ variant.sku }}"
                {%- unless variant.available %} aria-label="{{ variant.option1 }} — agotado"{% endunless -%}
              >
                {{ variant.option1 }}
              </button>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      <!-- Cantidad -->
      <div class="product-info__qty-row">
        <label class="product-info__label" for="qty-input">Cantidad</label>
        <div class="qty-stepper">
          <button type="button" class="qty-stepper__btn js-qty-minus" aria-label="Disminuir cantidad">−</button>
          <input
            class="qty-stepper__input"
            id="qty-input"
            type="number"
            name="quantity"
            value="1"
            min="1"
            max="99"
            aria-label="Cantidad"
          >
          <button type="button" class="qty-stepper__btn js-qty-plus" aria-label="Aumentar cantidad">+</button>
        </div>
      </div>

      <!-- Botón ATC -->
      <button
        class="product-info__atc js-add-to-cart js-product-atc"
        type="button"
        data-variant-id="{{ current_variant.id }}"
        data-product-title="{{ product.title | escape }}"
        {%- unless current_variant.available %} disabled aria-disabled="true"{% endunless -%}
        aria-label="Agregar {{ product.title }} al carrito"
      >
        {%- render 'icon', icon_name: 'cart', icon_size: 20 -%}
        {%- if current_variant.available -%}
          Agregar al carrito
        {%- else -%}
          Agotado
        {%- endif -%}
      </button>

      <!-- Tags -->
      {%- if product.tags.size > 0 -%}
        <div class="product-info__tags">
          {%- for tag in product.tags -%}
            <a href="/collections/all/{{ tag | handle }}" class="product-tag">{{ tag }}</a>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div><!-- /.product-info -->

  </div><!-- /.product-page__container -->
</section>

<!-- ═══ DESCRIPCIÓN COMPLETA ══════════════════════════════════════════════ -->
{%- if product.description != blank -%}
  <section class="product-details-section">
    <div class="container product-details">

      <!-- Tabs -->
      <div class="product-tabs" role="tablist" aria-label="Información del producto">
        <button class="product-tab is-active" role="tab" data-tab="description" aria-selected="true">
          Descripción
        </button>
        {%- if product.metafields.custom.specs != blank or product.tags.size > 0 -%}
          <button class="product-tab" role="tab" data-tab="specs" aria-selected="false">
            Especificaciones
          </button>
        {%- endif -%}
        <button class="product-tab" role="tab" data-tab="shipping" aria-selected="false">
          Envío
        </button>
      </div>

      <!-- Panel: descripción -->
      <div class="product-tab-panel is-active" id="tab-description" role="tabpanel">
        <div class="product-description rte">
          {{ product.description }}
        </div>
      </div>

      <!-- Panel: specs -->
      <div class="product-tab-panel" id="tab-specs" role="tabpanel" hidden>
        <div class="product-specs">
          {%- if product.vendor != blank -%}
            <div class="product-spec">
              <span class="product-spec__key">Marca</span>
              <span class="product-spec__val">{{ product.vendor }}</span>
            </div>
          {%- endif -%}
          {%- if current_variant.sku != blank -%}
            <div class="product-spec">
              <span class="product-spec__key">SKU</span>
              <span class="product-spec__val">{{ current_variant.sku }}</span>
            </div>
          {%- endif -%}
          {%- if current_variant.weight > 0 -%}
            <div class="product-spec">
              <span class="product-spec__key">Peso</span>
              <span class="product-spec__val">{{ current_variant.weight | weight_with_unit }}</span>
            </div>
          {%- endif -%}
          {%- if product.tags.size > 0 -%}
            <div class="product-spec">
              <span class="product-spec__key">Categorías</span>
              <span class="product-spec__val">{{ product.tags | join: ', ' }}</span>
            </div>
          {%- endif -%}
        </div>
      </div>

      <!-- Panel: envío -->
      <div class="product-tab-panel" id="tab-shipping" role="tabpanel" hidden>
        <div class="product-shipping-info">
          <div class="shipping-feature">
            {%- render 'icon', icon_name: 'truck', icon_size: 28 -%}
            <div>
              <strong>Entrega en 3–5 días hábiles</strong>
              <p>Envío a toda la República Mexicana.</p>
            </div>
          </div>
          <div class="shipping-feature">
            {%- render 'icon', icon_name: 'lock', icon_size: 28 -%}
            <div>
              <strong>Pago 100% seguro</strong>
              <p>Transacciones protegidas con encriptación SSL.</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>
{%- endif -%}

<!-- ═══ PRODUCTOS RELACIONADOS ════════════════════════════════════════════ -->
{%- if product.collections.first != blank -%}
  {%- assign related_col = product.collections.first -%}
  {%- assign related_products = related_col.products | where: 'id', product.id | map: 'id' -%}
  {%- assign related_count = 0 -%}
  {%- for p in related_col.products -%}{%- if p.id != product.id -%}{%- assign related_count = related_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
  {%- if related_count > 0 -%}
    <section class="related-products-section">
      <div class="container">
        <h2 class="related-products__title">Productos relacionados</h2>
        <div class="product-grid related-products__grid">
          {%- assign shown = 0 -%}
          {%- for p in related_col.products -%}
            {%- if p.id != product.id and shown < 5 -%}
              {%- assign card_product = p -%}
              {%- render 'product-card', card_product: card_product -%}
              {%- assign shown = shown | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}
{%- endif -%}

<!-- ═══ JS: galería + variantes + qty + tabs ══════════════════════════════ -->
<script>
(function () {
  /* ── Gallery ── */
  const mainImg = document.getElementById('gallery-main-img');
  document.querySelectorAll('.product-gallery__thumb').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.product-gallery__thumb').forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      if (mainImg) {
        mainImg.src = btn.dataset.full;
        mainImg.alt = btn.dataset.alt;
      }
    });
  });

  /* ── Variantes ── */
  const atcBtn       = document.querySelector('.js-product-atc');
  const priceEl      = document.getElementById('product-price');
  const optionText   = document.getElementById('selected-option-text');
  const skuEls       = document.querySelectorAll('.product-info__sku');

  document.querySelectorAll('.variant-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.variant-btn').forEach(b => b.classList.remove('is-selected'));
      btn.classList.add('is-selected');

      const available = btn.dataset.available === 'true';
      if (priceEl)  priceEl.textContent = btn.dataset.price;
      if (optionText) optionText.textContent = btn.dataset.option;
      if (skuEls.length) skuEls.forEach(el => { el.textContent = 'SKU: ' + btn.dataset.sku; });

      if (atcBtn) {
        atcBtn.dataset.variantId = btn.dataset.variantId;
        atcBtn.disabled = !available;
        atcBtn.setAttribute('aria-disabled', String(!available));
        atcBtn.innerHTML = atcBtn.querySelector('svg')
          ? atcBtn.querySelector('svg').outerHTML + (available ? ' Agregar al carrito' : ' Agotado')
          : (available ? 'Agregar al carrito' : 'Agotado');
      }
    });
  });

  /* ── Qty stepper ── */
  const qtyInput = document.getElementById('qty-input');
  document.querySelector('.js-qty-minus')?.addEventListener('click', () => {
    const v = parseInt(qtyInput.value, 10);
    if (v > 1) qtyInput.value = v - 1;
  });
  document.querySelector('.js-qty-plus')?.addEventListener('click', () => {
    const v = parseInt(qtyInput.value, 10);
    if (v < 99) qtyInput.value = v + 1;
  });

  /* Sobreescribir el add-to-cart para incluir qty */
  if (atcBtn) {
    atcBtn.addEventListener('click', e => {
      e.stopPropagation();
      const variantId    = atcBtn.dataset.variantId;
      const productTitle = atcBtn.dataset.productTitle;
      const qty          = parseInt(qtyInput?.value || '1', 10);
      if (variantId && typeof Cart !== 'undefined') Cart.addItem(variantId, qty, productTitle);
    });
  }

  /* ── Tabs ── */
  const tabs   = document.querySelectorAll('.product-tab');
  const panels = document.querySelectorAll('.product-tab-panel');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach(t => { t.classList.remove('is-active'); t.setAttribute('aria-selected', 'false'); });
      panels.forEach(p => { p.classList.remove('is-active'); p.hidden = true; });
      tab.classList.add('is-active');
      tab.setAttribute('aria-selected', 'true');
      const panel = document.getElementById('tab-' + target);
      if (panel) { panel.classList.add('is-active'); panel.hidden = false; }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Producto",
  "settings": []
}
{% endschema %}
